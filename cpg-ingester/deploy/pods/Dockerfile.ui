FROM python:3.12-slim
WORKDIR /app
COPY shared/ /app/shared/
RUN pip install --no-cache-dir /app/shared/
RUN pip install --no-cache-dir mlflow fastapi uvicorn jinja2 python-multipart click
COPY cpg-ingester/src/ /app/src/
ENV PYTHONPATH=/app/src
RUN chmod -R g=u /app
USER 1001
EXPOSE 8090
CMD ["python", "-m", "cpg_ingester.ui.app"]
