FROM image-registry.openshift-image-registry.svc:5000/openshift/python:3.12-ubi9
WORKDIR /app
RUN dnf install -y gcc gcc-c++ make && dnf clean all
COPY shared/ /app/shared/
RUN pip install --no-cache-dir /app/shared/
COPY cpg-ingester/pyproject.toml .
COPY cpg-ingester/src/ src/
RUN pip install --no-cache-dir .
COPY cpg-ingester/data/ data/
RUN chmod -R g=u /app
USER 1001
EXPOSE 8080
CMD ["uvicorn", "cpg_ingester.services.ingestion:app", "--host", "0.0.0.0", "--port", "8080"]
