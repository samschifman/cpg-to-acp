{
  "tools": [
    {
      "name": "register_guideline",
      "description": "Register a clinical practice guideline. Both decision models and recommendations reference this by cpg_id.",
      "inputSchema": {
        "type": "object",
        "required": ["cpg_id", "title"],
        "properties": {
          "cpg_id": {
            "type": "string",
            "description": "Unique guideline identifier (e.g., SYN-HTN-2026-001)"
          },
          "title": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "publication_date": {
            "type": "string",
            "format": "date"
          },
          "grading_system": {
            "type": "string",
            "enum": ["GRADE", "COR-LOE", "GRADE-COR-hybrid", "simplified", "verb-implied", "ungraded"]
          },
          "scope": {
            "type": "string"
          }
        }
      },
      "annotations": {
        "rest_method": "POST",
        "rest_path": "/api/v1/guidelines"
      }
    },
    {
      "name": "deploy_decision_model",
      "description": "Deploy a DMN decision model to the care plan writer's internal decision engine. The model becomes available for care plan generation and direct evaluation.",
      "inputSchema": {
        "type": "object",
        "required": ["dmn_xml"],
        "properties": {
          "dmn_xml": {
            "type": "string",
            "description": "DMN 1.3 XML document as a string"
          }
        }
      },
      "annotations": {
        "rest_method": "POST",
        "rest_path": "/api/v1/decisions/models",
        "rest_content_type": "application/xml"
      }
    },
    {
      "name": "list_decision_models",
      "description": "List all decision models currently deployed in the care plan writer.",
      "inputSchema": {
        "type": "object",
        "properties": {}
      },
      "annotations": {
        "rest_method": "GET",
        "rest_path": "/api/v1/decisions/models"
      }
    },
    {
      "name": "evaluate_decision",
      "description": "Evaluate a deployed DMN decision model with test inputs and return the decision output.",
      "inputSchema": {
        "type": "object",
        "required": ["model_id", "inputs"],
        "properties": {
          "model_id": {
            "type": "string",
            "description": "ID of the deployed decision model"
          },
          "inputs": {
            "type": "object",
            "additionalProperties": true,
            "description": "DMN input values keyed by input data name"
          }
        }
      },
      "annotations": {
        "rest_method": "POST",
        "rest_path": "/api/v1/decisions/evaluate/{model_id}"
      }
    },
    {
      "name": "ingest_recommendation",
      "description": "Ingest a clinical recommendation into the knowledge base for retrieval during care plan generation.",
      "inputSchema": {
        "type": "object",
        "required": ["id", "source_cpg", "title", "content", "recommendation_type"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Globally unique identifier (GUID)"
          },
          "source_cpg": {
            "type": "string",
            "description": "cpg_id of the source guideline"
          },
          "section": {
            "type": "string",
            "description": "Section reference within the CPG"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string",
            "description": "Recommendation text (plain text or markdown)"
          },
          "recommendation_type": {
            "type": "string",
            "enum": ["treatment", "diagnostic", "monitoring", "lifestyle", "educational", "referral", "screening", "contraindication", "process"]
          },
          "certainty": {
            "type": "object",
            "description": "Normalized certainty grade",
            "properties": {
              "strength": {
                "type": "string",
                "enum": ["strong-for", "conditional-for", "consensus", "no-recommendation", "conditional-against", "strong-against"]
              },
              "evidence_quality": {
                "type": "string",
                "enum": ["high", "moderate", "low", "very-low", "ungraded"]
              },
              "original_grade": {
                "type": "string"
              }
            }
          },
          "remarks": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Structured implementation context bullets"
          }
        }
      },
      "annotations": {
        "rest_method": "POST",
        "rest_path": "/api/v1/knowledge/recommendations"
      }
    },
    {
      "name": "ingest_recommendation_batch",
      "description": "Ingest a batch of recommendations from a single CPG.",
      "inputSchema": {
        "type": "object",
        "required": ["source_cpg", "recommendations"],
        "properties": {
          "source_cpg": {
            "type": "string"
          },
          "recommendations": {
            "type": "array",
            "items": {
              "type": "object",
              "description": "Recommendation objects (see ingest_recommendation for schema)"
            }
          }
        }
      },
      "annotations": {
        "rest_method": "POST",
        "rest_path": "/api/v1/knowledge/recommendations/batch"
      }
    },
    {
      "name": "search_recommendations",
      "description": "Search the knowledge base for clinical recommendations relevant to a query. Returns ranked summaries with similarity scores.",
      "inputSchema": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": {
            "type": "string",
            "description": "Natural language search query"
          },
          "top_k": {
            "type": "integer",
            "default": 5,
            "description": "Number of results to return"
          },
          "source_cpg": {
            "type": "string",
            "description": "Scope search to a specific CPG"
          },
          "recommendation_type": {
            "type": "string",
            "enum": ["treatment", "diagnostic", "monitoring", "lifestyle", "educational", "referral", "screening", "contraindication", "process"],
            "description": "Filter by recommendation type"
          },
          "strength_in": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["strong-for", "conditional-for", "consensus", "no-recommendation", "conditional-against", "strong-against"]
            },
            "description": "Only return recommendations with these strength values"
          }
        }
      },
      "annotations": {
        "rest_method": "POST",
        "rest_path": "/api/v1/knowledge/search"
      }
    },
    {
      "name": "generate_careplan",
      "description": "Generate a patient-specific FHIR CarePlan from patient data. Accepts a FHIR Bundle or IPS document, invokes applicable decision models, retrieves relevant recommendations, and assembles a FHIR CarePlan Bundle.",
      "inputSchema": {
        "type": "object",
        "required": ["patient_data"],
        "properties": {
          "patient_data": {
            "type": "object",
            "description": "FHIR Bundle or IPS document containing the patient's clinical data"
          }
        }
      },
      "annotations": {
        "rest_method": "POST",
        "rest_path": "/api/v1/careplans",
        "rest_content_type": "application/fhir+json"
      }
    },
    {
      "name": "get_careplan",
      "description": "Retrieve a previously generated care plan by ID.",
      "inputSchema": {
        "type": "object",
        "required": ["careplan_id"],
        "properties": {
          "careplan_id": {
            "type": "string"
          }
        }
      },
      "annotations": {
        "rest_method": "GET",
        "rest_path": "/api/v1/careplans/{careplan_id}"
      }
    },
    {
      "name": "approve_careplan",
      "description": "Approve or reject a generated care plan.",
      "inputSchema": {
        "type": "object",
        "required": ["careplan_id", "status"],
        "properties": {
          "careplan_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["approved", "rejected"]
          },
          "reason": {
            "type": "string",
            "description": "Reason for rejection (required when rejecting)"
          }
        }
      },
      "annotations": {
        "rest_method": "PUT",
        "rest_path": "/api/v1/careplans/{careplan_id}/status"
      }
    }
  ]
}
