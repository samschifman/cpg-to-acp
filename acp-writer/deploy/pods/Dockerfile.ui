FROM python:3.12-slim
WORKDIR /app
COPY shared/ /app/shared/
RUN pip install --no-cache-dir /app/shared/
RUN pip install --no-cache-dir mlflow requests fastapi uvicorn jinja2
COPY acp-writer/src/ /app/src/
ENV PYTHONPATH=/app/src
RUN chmod -R g=u /app
USER 1001
EXPOSE 8082
CMD ["uvicorn", "acp_writer.ui.app:app", "--host", "0.0.0.0", "--port", "8082"]
