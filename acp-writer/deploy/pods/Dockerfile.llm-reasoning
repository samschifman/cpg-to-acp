FROM registry.access.redhat.com/ubi9/python-312:latest
USER 0
WORKDIR /app
COPY shared/ /app/shared/
RUN pip install --no-cache-dir /app/shared/
RUN pip install --no-cache-dir boto3 mlflow langgraph langchain-openai pgvector sqlalchemy fastapi uvicorn python-multipart
COPY acp-writer/src/ /app/src/
ENV PYTHONPATH=/app/src
RUN chmod -R g=u /app
USER 1001
EXPOSE 8080
CMD ["uvicorn", "acp_writer.services.llm_reasoning:app", "--host", "0.0.0.0", "--port", "8080"]
