FROM python:3.12-slim
WORKDIR /app
COPY shared/ /app/shared/
RUN pip install --no-cache-dir /app/shared/
RUN pip install --no-cache-dir mlflow requests fastapi uvicorn
COPY acp-writer/src/ /app/src/
ENV PYTHONPATH=/app/src
RUN chmod -R g=u /app
USER 1001
EXPOSE 8080
CMD ["uvicorn", "acp_writer.services.fhir_server:app", "--host", "0.0.0.0", "--port", "8080"]
